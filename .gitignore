# Raw data -- 487MB, will break a git push (GitHub blocks files >100MB).
# Stage 3 reproduction supplies candidates.jsonl separately; you don't commit it.
data/raw/
*.jsonl

# Precomputed embeddings -- ~48MB, safe to commit directly (under GitHub's
# 100MB limit). DO commit candidate_embeddings.npy and jd_embedding.npy --
# they must be baked into the Docker image so rank.py never re-encodes
# during the timed 5-minute Stage 3 window.
data/precomputed/*.parquet

venv/
__pycache__/
*.pyc
.DS_Store
data/precomputed/submission_draft.csv
data/precomputed/submission_final.csv
